# Astro Explorer — backend environment variables.
# Copy this file to `.env` and fill in your values:
#     cp .env.example .env
# `start.sh` will auto-source `.env` if present. `.env` is gitignored.

# --- OpenAI (required for the /explain vision-LLM feature) ---
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_ME

# Vision model for /explain. Default: gpt-4o-mini (~$0.0004/call).
# Upgrade to gpt-4o (~$0.007/call) if mini's explanations are too terse.
# OPENAI_VISION_MODEL=gpt-4o-mini

# --- NASA APOD (optional) ---
# DEMO_KEY works but is shared/rate-limited to 50 requests/day per IP.
# Get a free personal key at https://api.nasa.gov/ for higher limits.
# NASA_API_KEY=DEMO_KEY
